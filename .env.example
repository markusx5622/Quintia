# Database
DATABASE_URL="postgresql://user:password@localhost:5432/quintia?schema=public"

# AI Providers
QUINTIA_LLM_PROVIDER=openai # or anthropic
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Inngest (Production & Local)
INNGEST_EVENT_KEY=      # Optional for local, required for prod
INNGEST_SIGNING_KEY=    # Optional for local, required for prod
# Inngest Dev Server usually runs on http://localhost:8288
